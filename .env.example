# SentinelAI — Docker Compose environment.
# Copy to `.env` (gitignored) and change every credential before any
# non-local deployment. Compose refuses to start if required values are missing.

# --- Application ---
SENTINEL_ENVIRONMENT=production
SENTINEL_LOG_LEVEL=INFO
# JSON array, matches the frontend dev servers by default
SENTINEL_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- PostgreSQL (consumed by both the postgres image and the API) ---
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=sentinelai

# Restricted, non-owner role the API connects as, so PostgreSQL Row-Level
# Security actually restricts it (POSTGRES_USER above owns the schema and
# is a superuser in this image, so RLS would be a no-op for it). Created
# automatically by the tenant-isolation-rls migration on first `alembic
# upgrade head`. Migrations always run as POSTGRES_USER, never this role.
APP_DB_USER=sentinel_app
APP_DB_PASSWORD=change-me-strong-password

# BYPASSRLS role used ONLY by pre-authentication flows (login, token
# refresh, password reset), which by definition run before a tenant
# context exists. Grants limited to auth-domain tables. Created by the
# auth-role migration on `alembic upgrade head`.
AUTH_DB_USER=sentinel_auth
AUTH_DB_PASSWORD=change-me-strong-password

# --- Redis ---
REDIS_PASSWORD=change-me-redis-password

# --- MinIO (root credentials double as the API's access keys in dev;
#     use a dedicated service account with a scoped policy in production) ---
MINIO_ROOT_USER=sentinel-minio
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET=sentinel-evidence

# --- Auth (JWT) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-random-48-byte-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# --- RBAC bootstrap (read once by the Alembic seed migration) ---
# Leave ADMIN_EMAIL/ADMIN_PASSWORD unset to skip creating a first admin
# account (roles and permissions still get seeded either way).
DEFAULT_ORGANIZATION_NAME=SentinelAI Demo
DEFAULT_ORGANIZATION_SLUG=sentinelai-demo
ADMIN_EMAIL=admin@sentinelai.demo
ADMIN_PASSWORD=change-me-strong-password

# --- Compliance Copilot (app/ai/compliance) ---
# Required — get one at https://aistudio.google.com/apikey (free tier).
# Embeddings and chat generation both run through this one key/account.
GEMINI_API_KEY=change-me
GEMINI_CHAT_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
