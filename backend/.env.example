# Backend environment for running the API directly on the host
# (uvicorn app.main:app). Copy to backend/.env and fill in credentials.
# When running under Docker Compose, these are injected by docker-compose.yml
# instead — this file is only for host-based development.

SENTINEL_ENVIRONMENT=development
SENTINEL_LOG_LEVEL=INFO
# Leave unset for auto (JSON everywhere except development)
# SENTINEL_LOG_JSON=false

# JSON array of allowed origins for CORS
SENTINEL_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- PostgreSQL ---
SENTINEL_POSTGRES_HOST=localhost
SENTINEL_POSTGRES_PORT=5432
SENTINEL_POSTGRES_USER=sentinel
SENTINEL_POSTGRES_PASSWORD=change-me
SENTINEL_POSTGRES_DB=sentinelai

# Restricted, non-owner role for the running app — see app_db_user's
# docstring in app/core/config.py. Created by the tenant-isolation-rls
# migration. Leave unset to fall back to the owner role above (RLS then
# stops being a real backstop, only the ORM-level filter remains).
SENTINEL_APP_DB_USER=sentinel_app
SENTINEL_APP_DB_PASSWORD=change-me

# BYPASSRLS role for pre-authentication lookups only — see the
# auth_db_user docstring in app/core/config.py.
SENTINEL_AUTH_DB_USER=sentinel_auth
SENTINEL_AUTH_DB_PASSWORD=change-me

# --- Redis ---
SENTINEL_REDIS_HOST=localhost
SENTINEL_REDIS_PORT=6379
SENTINEL_REDIS_PASSWORD=change-me

# --- MinIO ---
SENTINEL_MINIO_ENDPOINT=localhost:9000
SENTINEL_MINIO_ACCESS_KEY=sentinel-minio
SENTINEL_MINIO_SECRET_KEY=change-me
SENTINEL_MINIO_SECURE=false
SENTINEL_MINIO_BUCKET=sentinel-evidence

# --- Auth (JWT) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SENTINEL_JWT_SECRET_KEY=change-me-to-a-random-48-byte-secret
SENTINEL_JWT_ALGORITHM=HS256
SENTINEL_ACCESS_TOKEN_EXPIRE_MINUTES=15
SENTINEL_REFRESH_TOKEN_EXPIRE_DAYS=30
SENTINEL_PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# --- Auth rate limiting (Redis-backed) ---
SENTINEL_MAX_LOGIN_ATTEMPTS=5
SENTINEL_LOGIN_LOCKOUT_MINUTES=15
SENTINEL_MAX_PASSWORD_RESET_REQUESTS=3
SENTINEL_PASSWORD_RESET_THROTTLE_MINUTES=60

# --- RBAC bootstrap ---
# Read once by the Alembic seed migration to create the first Admin
# account + default organization. Leave admin_email/admin_password unset
# to skip admin creation entirely (the migration will still seed roles
# and permissions).
SENTINEL_DEFAULT_ORGANIZATION_NAME=SentinelAI Demo
SENTINEL_DEFAULT_ORGANIZATION_SLUG=sentinelai-demo
SENTINEL_ADMIN_EMAIL=admin@sentinelai.demo
SENTINEL_ADMIN_PASSWORD=change-me

# --- Compliance Copilot (app/ai/compliance) ---
# Required for embeddings + chat generation — get one at
# https://aistudio.google.com/apikey (free tier).
SENTINEL_GEMINI_API_KEY=change-me
SENTINEL_GEMINI_CHAT_MODEL=gemini-flash-latest
SENTINEL_GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
SENTINEL_CHROMA_HOST=localhost
SENTINEL_CHROMA_PORT=8000
